{# extends 'base.html.twig' #}

{# block body #}
  <div class="modal fade" id="vmailModal" role="dialog">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h4 class="modal-title">{% trans %}Domain creation{% endtrans %}</h4>
        </div>
        {% if form is defined %}
        {{ form_start(form) }}
          <div class="modal-body">
            {{ form_widget(form.name) }}
            {{ form_widget(form.active) }}
          </div>
          <div class="modal-footer">
            <input type="submit" class="btn btn-default" data-dismiss="modal" value="{% trans %}Create{% endtrans %}" />
          </div>
        {{ form_end(form) }}
        {% endif %}
      </div>
    </div>
  </div>
{# endblock #}
